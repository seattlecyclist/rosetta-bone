# Required: Anthropic API key for SFT-pair generation.
# Get one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Recommended: Hugging Face read token. Without it, downloads of
# BAAI/bge-small-en-v1.5 (~130MB) and mlx-community/Meta-Llama-3.1-8B-
# Instruct-4bit (~4.5GB) hit anonymous rate limits and you'll see this
# warning on every run:
#
#   "You are sending unauthenticated requests to the HF Hub. Please set
#    a HF_TOKEN to enable higher rate limits and faster downloads."
#
# Create a free Read-scope token at https://huggingface.co/settings/tokens.
HF_TOKEN=

# Optional: override the default Hugging Face cache location.
# HF_HOME=~/.cache/huggingface
